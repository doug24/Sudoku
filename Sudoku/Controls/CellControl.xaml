<UserControl x:Class="Sudoku.CellControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sudoku"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=local:CellViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="50" d:DesignWidth="50">

    <UserControl.Resources>

        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" TrueValue="Visible" FalseValue="Hidden" />
        <local:BoolToColorConverter x:Key="BoolToColorConverter"/>

        <DataTemplate x:Key ="CandidateTemplate">
            <Viewbox>
                <Viewbox.Style>
                    <Style TargetType="Viewbox">
                        <Setter Property="Margin" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsKillerMode, RelativeSource={RelativeSource AncestorType=local:CellControl}}" Value="True">
                                <Setter Property="Margin" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Viewbox.Style>
                <TextBlock Text="{Binding Number}" 
                           Foreground="{Binding IsHighlight, Converter={StaticResource BoolToColorConverter}}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Visibility="{Binding Visible, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Viewbox>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Border Background="{Binding Background}" Margin="2"/>

        <!-- Cage dashed borders: each edge is an independent line -->
        <Border BorderThickness="0,1.5,0,0" BorderBrush="{Binding CageTopBrush}" Margin="1,1,1,0"
                Visibility="{Binding IsKillerMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <Border BorderThickness="0,0,1.5,0" BorderBrush="{Binding CageRightBrush}" Margin="0,1,1,1"
                Visibility="{Binding IsKillerMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <Border BorderThickness="0,0,0,1.5" BorderBrush="{Binding CageBottomBrush}" Margin="1,0,1,1"
                Visibility="{Binding IsKillerMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <Border BorderThickness="1.5,0,0,0" BorderBrush="{Binding CageLeftBrush}" Margin="1,1,0,1"
                Visibility="{Binding IsKillerMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Cage sum label in top-left corner -->
        <TextBlock Text="{Binding CageSumText}"
                   FontSize="10" 
                   Margin="3,1,0,0"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left"
                   Foreground="{Binding CageSumForeground}"
                   Visibility="{Binding IsKillerMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <Ellipse Stroke="{Binding HighlightBrush}" StrokeThickness="2" Margin="0" 
                 Visibility="{Binding IsHighlight, Converter={StaticResource BoolToVisibilityConverter}}"/>
        <Viewbox>
            <TextBlock Text="{Binding Number}" 
                       FontSize="44" 
                       Margin="0,0,0,2"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{Binding Foreground}"/>
        </Viewbox>
        <ItemsControl ItemsSource="{Binding Path=Candidates}" x:Name="Candidates"
                          ItemTemplate="{StaticResource CandidateTemplate}">
            <ItemsControl.Style>
                <Style TargetType="ItemsControl">
                    <Setter Property="Margin" Value="0"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsKillerMode}" Value="True">
                            <Setter Property="Margin" Value="8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ItemsControl.Style>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="3" Columns="3" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

    </Grid>
</UserControl>
